{
  "name": "raze",
  "version": "0.1.0",
  "description": "Raze Automates Zero-Config Environment",
  "type": "module",
  "bin": {
    "raze": "./src/cli/index.ts"
  },
  "scripts": {
    "start": "bun run src/cli/index.ts",
    "build": "bun build ./src/cli/index.ts --compile --outfile dist/raze",
    "build:linux": "bun build ./src/cli/index.ts --compile --target=bun-linux-x64-musl --outfile dist/raze-linux-x64",
    "test": "bun test"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/js-yaml": "^4.0.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
